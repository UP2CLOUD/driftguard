NEXT_PUBLIC_API_URL=http://localhost:8000
# GitHub App install page (optional; defaults to https://github.com/apps/driftguard-dev/installations/new)
NEXT_PUBLIC_GITHUB_APP_INSTALL_URL=
# Or set slug only: NEXT_PUBLIC_GITHUB_APP_SLUG=driftguard-dev
# Legacy alias: NEXT_PUBLIC_GITHUB_APP_URL=
# Required in production for Auth.js (e.g. https://driftguard-blue.vercel.app)
AUTH_URL=
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
