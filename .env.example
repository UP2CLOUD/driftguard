# ────────────────────────────────────────────────────────────────────────────
# DriftGuard — environment variables
# Copy to .env and fill in values. Never commit .env.
# ────────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=dev                                  # dev | prod
PUBLIC_BASE_URL=http://localhost:3000

# ── Database (Neon / Supabase / local postgres) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/driftguard

# ── Auth (NextAuth) ────────────────────────────────────────────────────────
AUTH_SECRET=                                     # openssl rand -hex 32

# ── GitHub OAuth App (user login) ─────────────────────────────────────────
AUTH_GITHUB_ID=                                  # Settings → Developer → OAuth Apps
AUTH_GITHUB_SECRET=

# ── GitHub App (PR reviews + webhooks) ────────────────────────────────────
GITHUB_APP_ID=                                   # App settings → App ID
GITHUB_APP_PRIVATE_KEY=                          # PEM key (replace \n with literal newlines)
GITHUB_WEBHOOK_SECRET=                           # Random secret set in App settings

# ── AI (Claude primary, OpenAI fallback) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=                                  # Optional — fallback when Anthropic down
LLM_FALLBACK_ENABLED=true

# ── Infracost (cost delta) ─────────────────────────────────────────────────
INFRACOST_API_KEY=                               # infracost.io → API keys

# ── Redis / Upstash (Celery broker) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0               # Upstash: rediss://...

# ── Object storage (Cloudflare R2 or S3) ──────────────────────────────────
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_BUCKET=driftguard-plans
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# ── Stripe (billing) ──────────────────────────────────────────────────────
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...                       # Pro monthly price ID
STRIPE_PRICE_TEAM=price_...                      # Team monthly price ID

# ── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=DriftGuard <noreply@driftguard.io>

# ── Observability ──────────────────────────────────────────────────────────
POSTHOG_API_KEY=phc_...
SENTRY_DSN=https://...@sentry.io/...

# ── Frontend (Vercel env vars — must be prefixed NEXT_PUBLIC_) ────────────
NEXT_PUBLIC_API_URL=https://api.driftguard.io        # Cloud Run URL after deploy
NEXT_PUBLIC_SITE_URL=https://driftguard-blue.vercel.app
NEXT_PUBLIC_GITHUB_APP_SLUG=driftguard-app           # GitHub App slug
NEXT_PUBLIC_GITHUB_APP_INSTALL_URL=https://github.com/apps/driftguard-app/installations/new
SECRET_KEY=dev-only-change-me                        # Must match API SECRET_KEY for SSR→API calls

# ── AWS (STS cross-account for drift detection) ───────────────────────────
AWS_REGION=eu-west-1
