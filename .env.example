# --- API ---
ENVIRONMENT=dev
DATABASE_URL=postgresql+asyncpg://driftguard:driftguard@localhost:5432/driftguard
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me

# --- GitHub App ---
GITHUB_APP_ID=3758793
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- LLM ---
ANTHROPIC_API_KEY=

# --- Integrations ---
INFRACOST_API_KEY=

# --- Storage (Cloudflare R2 or S3) ---
S3_ENDPOINT=
S3_BUCKET=driftguard-plans
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Stripe ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
PUBLIC_BASE_URL=http://localhost:3000

# --- Web (Vercel) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
# Must match API SECRET_KEY for server-side billing routes (/api/billing/*)
SECRET_KEY=change-me
AUTH_SECRET=
AUTH_URL=http://localhost:3000
RESEND_API_KEY=

# Web / NextAuth (apps/web/.env.local)
AUTH_GITHUB_ID=Ov23liHgVqmP6H8gTfsL
AUTH_GITHUB_SECRET=your-github-oauth-client-secret
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-api-domain.com

GITHUB_PRIVATE_KEY=<contents of .pem file, newlines replaced with \n>
NEXT_PUBLIC_GITHUB_APP_SLUG=driftguard-app

# ── Redis (Upstash — copy URL from upstash.com dashboard) ───────────────────
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=driftguard-plans
S3_ACCESS_KEY=<r2-access-key-id>
S3_SECRET_KEY=<r2-secret-access-key>

# ── LLM router ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=          # optional — used as fallback if Claude returns 529
LLM_FALLBACK_ENABLED=true

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=DriftGuard <noreply@driftguard.io>

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://<key>@o<id>.ingest.sentry.io/<project>
POSTHOG_API_KEY=phc_xxxxxxxx
POSTHOG_HOST=https://eu.posthog.com   # EU data residency

# ── Grafana Cloud ─────────────────────────────────────────────────────────────
# No code needed — configure Grafana Alloy to scrape /metrics
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-0.grafana.net/otlp

# Frontend observability
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<id>.ingest.sentry.io/<project>
SENTRY_ORG=driftguard
SENTRY_PROJECT=driftguard-web
